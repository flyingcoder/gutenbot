{
    "name": "gutenbot/gutenbot",
    "description": "AI-powered WordPress Gutenberg page generator.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.5"
    },
    "autoload": {
        "classmap": ["includes/"]
    },
    "autoload-dev": {},
    "scripts": {
        "test": "phpunit",
        "test-unit": "phpunit --testsuite unit",
        "test-integration": "phpunit --testsuite integration"
    }
}
